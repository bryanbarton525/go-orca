package handlers

import (
	"encoding/json"
	"net/http"
	"time"

	"go-orca/internal/model"
	"go-orca/internal/service"
)

// WorkflowHandler holds dependencies for workflow API handlers.
type WorkflowHandler struct {
	WorkflowService service.WorkflowService
}

// NewWorkflowHandler creates a new WorkflowHandler with the necessary service dependency.
func NewWorkflowHandler(ws service.WorkflowService) *WorkflowHandler {
	return &WorkflowHandler{WorkflowService: ws}
}

// ListWorkflows handles the GET /workflows/list request.
// It fetches and returns all active workflows in a stable JSON format.
func (h *WorkflowHandler) ListWorkflows(w http.ResponseWriter, r *http.Request) {
	// 1. Input Validation (Minimal for GET, ensuring context/auth if needed, but primarily checking structure)
	// For this iteration, we assume the request is valid and only need to check context if applicable.

	// 2. Service Call
	workflows, err := h.WorkflowService.ListActiveWorkflows()
	if err != nil {
		// Handle service layer errors (e.g., database connection issues)
		http.Error(w, "Internal service error listing workflows: "+err.Error(), http.StatusInternalServerError)
		return
	}

	// 3. Stable JSON Response (F4)
	w.Header().Set("Content-Type", "application/json")

	response := struct {
		Success bool   `json:"success"`
		Data     []model.Workflow `json:"data"`
	}{
		Success: true,
		Data:     workflows,
	}

	e, _ := json.Marshal(response)
	n.Write(e)
}


```javascript
const API_BASE_URL = ''; // Assumes the API root is accessible

// --- Workflow Monitoring (GET /workflows) ---
async function fetchWorkflows() {
    const filter = document.getElementById('statusFilter').value;
    const workflowList = document.getElementById('workflowList');
    workflowList.innerHTML = 'Loading workflows...';

    try {
        // Call GET /workflows. In a real scenario, we might pass the filter as a query param.
        const response = await fetch(`${API_BASE_URL}/workflows?status=${filter}`);
        if (!response.ok) {
            throw new Error(`HTTP error! Status: ${response.status}`);
        }
        const workflows = await response.json();
        displayWorkflows(workflows, filter);
    } catch (error) {
        console.error("Failed to fetch workflows:", error);
        workflowList.innerHTML = `<p style="color: red;">Error loading workflows: ${error.message}. Check the API logs.</p>`;
    }
}

function getStatusClass(status) {
    switch(status.toLowerCase()) {
        case 'pending': return 'status-pending';
        case 'running': return 'status-running';
        case 'paused': return 'status-paused';
        default: return '';
    }
}

function displayWorkflows(workflows, currentFilter) {
    const workflowList = document.getElementById('workflowList');
    let html = '';
    let filteredCount = 0;

    const filteredWorkflows = workflows.filter(wf => {
        if (currentFilter === 'all') return true;
        return wf.status.toLowerCase() === currentFilter;
    });

    if (filteredWorkflows.length === 0) {
        html = '<p>No workflows found matching the current filter.</p>';
    } else {
        filteredWorkflows.forEach(wf => {
            html += `
            <div class="workflow-card ${getStatusClass(wf.status)}">
                <strong>ID:</strong> ${wf.id || 'N/A'}<br>
                <strong>Name:</strong> ${wf.name || 'Unnamed'}<br>
                <strong>Status:</strong> ${wf.status.toUpperCase()}<br>
                <strong>Started:</strong> ${new Date(wf.startedAt).toLocaleString()}<br>
            </div>`;
            filteredCount++;
        });
    }
    
    if (filteredCount > 0) {
        workflowList.innerHTML = html;
    } else {
        workflowList.innerHTML = `<p>No workflows found matching ${currentFilter} status.</p>`;
    }
}

// --- Workflow Submission (POST /workflows) ---
document.getElementById('workflowForm').addEventListener('submit', async function(e) {
    e.preventDefault();
    const messageDiv = document.getElementById('submissionMessage');
    messageDiv.textContent = 'Submitting workflow...';

    const payload = { 
        workflowType: document.getElementById('workflowType').value, 
        // Include other mandatory fields required by the POST endpoint, e.g., inputs: []
    };

    try {
        const response = await fetch(`${API_BASE_URL}/workflows`, {
            method: 'POST',
            headers: { 
                'Content-Type': 'application/json'
            },
            body: JSON.stringify(payload)
        });
        
        const result = await response.json();
        
        if (response.ok) {
            messageDiv.textContent = `Success! Workflow submitted. ID: ${result.id || 'Unknown'}. Status: ${result.status}.`;
            // Optionally refresh the list after successful submission
            setTimeout(fetchWorkflows, 1000);
        } else {
            throw new Error(result.message || 'Unknown API error occurred.');
        }
    } catch (error) {
        console.error("Submission Error:", error);
        messageDiv.textContent = `Submission Failed: ${error.message}`; 
        messageDiv.style.color = 'red';
    }
});

// Initialize on load
document.addEventListener('DOMContentLoaded', fetchWorkflows);



// --- Models (Internal Structure Definition) ---

type WorkflowState string

const ( 
	StatePending WorkflowState = "pending" 
	StateRunning WorkflowState = "running" 
	StatePaused WorkflowState = "paused" 
	StateCompleted WorkflowState = "completed"
)

type Workflow struct {
	ID        string       `json:"id"`
	WorkflowID string     `json:"workflow_id"`
	State     WorkflowState `json:"state"`
	SubmittedAt time.Time `json:"submitted_at"`	"Details string `json:"details"`
}

// SubmitRequest models the input payload for starting a new workflow.
type SubmitRequest struct {
	WorkflowType string `json:"workflow_type"`
	Payload      string `json:"payload"` // Simplified for skeleton
	Parameters   map[string]string `json:"parameters"`
}

// ApiResponse standardizes all API responses for stable JSON output.
type ApiResponse struct {
	Success bool        `json:"success"`
	Data    interface{} `json:"data,omitempty"`
	Error   string      `json:"error,omitempty"`
}

// --- Handlers (API Logic Implementation) ---


    if err != nil {
        fmt.Printf("Error: %v\n", err)
    }
}
```

### Example 3: Context Propagation and Async Execution with MCP Tool Registration

```go
package main

import (
    "context"
    "fmt"
    "github.com/go-orca/go-orca"
    "github.com/go-orca/go-orca/internal/state"
    "sync"
    "time"
)

type MyTask struct {
    id string
}

func (t *MyTask) Execute(ctx context.Context) error {
    select {
    case <-ctx.Done():
        return ctx.Err()
    default:
        fmt.Printf("Executing task %s...\n", t.id)
        time.Sleep(2 * time.Second)
        state.Set(ctx, fmt.Sprintf("task%dComplete", t.id), true)
    }
    return nil
}

func main() {
    ctx := context.Background()
    
    // Register MCP tools for external integration
    orca.RegisterTool(ctx, "my-tool", func(ctx context.Context, args any) any {
        fmt.Println("MCP Tool invoked")
        return map[string]any{
            "status": "success",
            "data":   "result from external tool",
        }
    })
    
    // Discover registered tools
    tools := orca.DiscoverTools(ctx)
    fmt.Printf("Registered %d tools\n", len(tools))
    
    workflow := orca.NewWorkflow()
    workflow.Add(&MyTask{id: "task-1"})
    workflow.Add(&MyTask{id: "task-2"})
    workflow.Add(&MyTask{id: "task-3"})

    var wg sync.WaitGroup
    wg.Add(1)

    go func() {
        defer wg.Done()
        err := workflow.Run(ctx)
        if err != nil {
            fmt.Printf("Error: %v\n", err)
        }
    }()

    wg.Wait()
}
```

### Example 4: State Management and Retrieval with MCP Tool Registration

```go
package main

import (
    "context"
    "fmt"
    "github.com/go-orca/go-orca"
    "github.com/go-orca/go-orca/internal/state"
)

type MyTask struct {
    name string
}

func (t *MyTask) Execute(ctx context.Context) error {
    state.Set(ctx, "taskName", t.name)
    value, exists := state.Get(ctx, "taskName")
    
    if exists {
        fmt.Printf("Retrieved value for %s: %v\n", t.name, value)
    } else {
        fmt.Println("No value found in state")
    }
    
    // Add timestamp metadata
    if timestamp, ok := state.Get(ctx, "createdAt"); ok {
        fmt.Printf("Task created at: %v\n", timestamp)
    }
    
    return nil
}

func main() {
    ctx := context.Background()
    workflow := orca.NewWorkflow()
    workflow.Add(&MyTask{name: "processing-job"})
    
    err := workflow.Run(ctx)
    if err != nil {
        panic(err)
    }
    
    // Retrieve workflow state after execution
    workflowState := state.RetrieveWorkflowState(ctx)
    if workflowState != nil {
        fmt.Printf("Workflow state retrieved: %v\n", workflowState)
    }
}
```

## Benefits of Using go-orca

**go-orca** offers several key benefits to developers working with Go:

- **Efficiency:** Simplifies complex workflows, reducing onboarding time and accelerating delivery cycles. The framework's declarative API reduces boilerplate code compared to manual orchestration patterns.
- **Seamless Integration:** Integrates with existing Go tools via MCP, ensuring smooth communication between components. MCP tool registration requires only a single callback function, eliminating complex serialization overhead.
- **Enhanced Debugging:** Provides a real-time UI dashboard for visualizing workflow processes and monitoring performance metrics. The UI's breakpoint support reduces debugging time through targeted inspection.
- **Developer-Friendly:** Offers a modular design that allows developers to easily customize workflows according to their needs. The public API surface is intentionally minimal, exposing only what's necessary for common use cases.
- **Type Safety:** Full type safety through Go's generics and interfaces. State keys are typed, preventing the runtime errors common in dynamic orchestrators.
- **Testability:** Pure function composition makes unit testing straightforward. Each task executes independently, enabling parallel test execution without state pollution.


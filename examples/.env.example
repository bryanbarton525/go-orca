# .env.example — go-orca environment variable overrides
#
# Copy to .env and fill in values. All variables are optional — any key set
# here overrides the equivalent value in your YAML config file.
#
# Format: GOORCA_<SECTION>_<KEY>
# Nested keys use _ as separator (e.g. providers.openai.api_key →
# GOORCA_PROVIDERS_OPENAI_API_KEY).
#
# Usage:
#   export $(grep -v '^#' .env | xargs) && ./go-orca-api -config go-orca.yaml
# or with a tool like direnv / docker --env-file.

# ─── HTTP server ───────────────────────────────────────────────────────────────
# GOORCA_SERVER_HOST=0.0.0.0
# GOORCA_SERVER_PORT=8080
# GOORCA_SERVER_MODE=release           # debug | release | test
# GOORCA_SERVER_READ_TIMEOUT=30s
# GOORCA_SERVER_WRITE_TIMEOUT=60s
# GOORCA_SERVER_SHUTDOWN_TIMEOUT=15s

# ─── Database ─────────────────────────────────────────────────────────────────
# SQLite (default — no configuration required):
#   driver defaults to "sqlite", dsn defaults to "go-orca.db".
#   Leave this entire section commented out when using SQLite.
#
# PostgreSQL — uncomment and fill in all three lines:
# GOORCA_DATABASE_DRIVER=postgres
# GOORCA_DATABASE_DSN=postgres://go-orca:change-me@localhost:5432/go-orca?sslmode=disable
#
# Optional pool tuning (applies to both drivers):
# GOORCA_DATABASE_MAX_OPEN_CONNS=25
# GOORCA_DATABASE_MAX_IDLE_CONNS=5
# GOORCA_DATABASE_CONN_MAX_LIFETIME=5m
# GOORCA_DATABASE_AUTO_MIGRATE=true

# ─── Logging ──────────────────────────────────────────────────────────────────
# GOORCA_LOGGING_LEVEL=info            # debug | info | warn | error
# GOORCA_LOGGING_FORMAT=json           # json | console

# ─── Scoping ──────────────────────────────────────────────────────────────────
# GOORCA_SCOPING_MODE=global           # global | org | team | hosted
# GOORCA_SCOPING_ALLOW_GLOBAL=true
# GOORCA_SCOPING_ALLOW_ORG=false
# GOORCA_SCOPING_ALLOW_TEAM=false
# GOORCA_SCOPING_DEFAULT_TENANT=default
# GOORCA_SCOPING_DEFAULT_SCOPE=global

# ─── Providers ────────────────────────────────────────────────────────────────

# OpenAI
# GOORCA_PROVIDERS_OPENAI_ENABLED=true
# GOORCA_PROVIDERS_OPENAI_API_KEY=sk-...
# GOORCA_PROVIDERS_OPENAI_BASE_URL=               # leave empty for api.openai.com
# GOORCA_PROVIDERS_OPENAI_DEFAULT_MODEL=gpt-4o
# GOORCA_PROVIDERS_OPENAI_TIMEOUT=120s

# Ollama (local)
# GOORCA_PROVIDERS_OLLAMA_ENABLED=true
# GOORCA_PROVIDERS_OLLAMA_HOST=http://localhost:11434
# GOORCA_PROVIDERS_OLLAMA_DEFAULT_MODEL=llama3
# GOORCA_PROVIDERS_OLLAMA_TIMEOUT=120s

# GitHub Copilot
# GOORCA_PROVIDERS_COPILOT_ENABLED=true
# GOORCA_PROVIDERS_COPILOT_GITHUB_TOKEN=ghp_...
# GOORCA_PROVIDERS_COPILOT_CLI_PATH=              # leave empty to use gh from $PATH
# GOORCA_PROVIDERS_COPILOT_DEFAULT_MODEL=gpt-4o

# ─── Workflow engine ──────────────────────────────────────────────────────────
# GOORCA_WORKFLOW_MAX_CONCURRENT_WORKFLOWS=10
# GOORCA_WORKFLOW_MAX_CONCURRENT_TASKS=50
# GOORCA_WORKFLOW_DEFAULT_PERSONA_TIMEOUT_MS=120000
# GOORCA_WORKFLOW_EVENT_RETENTION_DAYS=90
# GOORCA_WORKFLOW_ARTIFACT_STORAGE_PATH=./artifacts
# GOORCA_WORKFLOW_HANDOFF_TIMEOUT=5m

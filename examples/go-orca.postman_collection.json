              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('status is 201', () => {",
                  "    pm.expect(pm.response.code).to.eql(201);",
                  "});",
                  "const body = pm.response.json();",
                  "pm.collectionVariables.set('workflowId', body.id);",
                  "console.log('workflowId set to', body.id);"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Get Workflow",
          "request": {
            "method": "GET",
            "header": [
              { "key": "X-Tenant-ID", "value": "{{tenantId}}", "description": "Omit to use server default" },
              { "key": "X-Scope-ID", "value": "{{scopeId}}", "description": "Omit to use server default" }
            ],
            "url": {
              "raw": "{{baseUrl}}/workflows/{{workflowId}}",
              "host": ["{{baseUrl}}"],
              "path": ["workflows", "{{workflowId}}"]
            },
            "description": "Retrieve the full WorkflowState for a single workflow, including all structured outputs (constitution, requirements, design, tasks, artifacts, finalization) and Refiner suggestions."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('status is 200', () => pm.response.to.have.status(200));",
                  "const body = pm.response.json();",
                  "pm.test('has id', () => pm.expect(body).to.have.property('id'));",
                  "pm.test('has status', () => pm.expect(body).to.have.property('status'));",
                  "console.log('workflow status:', body.status);",
                  "if (body.all_suggestions && body.all_suggestions.length > 0) {",
                  "    console.log('Refiner suggestions:', body.all_suggestions.length);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Get Workflow Events",
          "request": {
            "method": "GET",
            "header": [
              { "key": "X-Tenant-ID", "value": "{{tenantId}}", "description": "Omit to use server default" },
              { "key": "X-Scope-ID", "value": "{{scopeId}}", "description": "Omit to use server default" }
            ],
            "url": {
              "raw": "{{baseUrl}}/workflows/{{workflowId}}/events",
              "host": ["{{baseUrl}}"],
              "path": ["workflows", "{{workflowId}}", "events"]
            },
            "description": "Return the full event journal for a workflow in chronological order. The API returns an envelope with `events` and `count`. Event types use dotted names such as `state.transition`, `persona.started`, and `artifact.produced`."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('status is 200', () => pm.response.to.have.status(200));",
                  "const body = pm.response.json();",
                  "pm.test('response has events array', () => {",
                  "    pm.expect(body.events).to.be.an('array');",
                  "});",
                  "const events = body.events;",
                  "console.log('total events:', body.count);",
                  "const byType = {};",
                  "events.forEach(e => { byType[e.type] = (byType[e.type] || 0) + 1; });",
                  "console.log('event breakdown:', JSON.stringify(byType));"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Stream Workflow Events (SSE)",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "text/event-stream" },
              { "key": "X-Tenant-ID", "value": "{{tenantId}}", "description": "Omit to use server default" },
              { "key": "X-Scope-ID", "value": "{{scopeId}}", "description": "Omit to use server default" }
            ],
            "url": {
              "raw": "{{baseUrl}}/workflows/{{workflowId}}/stream?timeout=300",
              "host": ["{{baseUrl}}"],
              "path": ["workflows", "{{workflowId}}", "stream"],
              "query": [
                { "key": "timeout", "value": "300", "description": "Max stream duration in seconds" }
              ]
            },
            "description": "Opens a Server-Sent Events stream of workflow events in real time. The stream closes automatically when the workflow reaches a terminal state.\n\n**Note:** Postman does not natively render SSE streams. Use the curl command below for live streaming:\n\n```\ncurl -N http://localhost:8080/workflows/{{workflowId}}/stream\n```\n\nFor nginx reverse proxy, set `proxy_buffering off` to avoid event buffering."
          }
        },
        {
          "name": "Cancel Workflow",
          "request": {
            "method": "POST",
            "header": [
              { "key": "X-Tenant-ID", "value": "{{tenantId}}", "description": "Omit to use server default" },

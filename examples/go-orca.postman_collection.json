        {
          "name": "Test Provider — OpenAI",
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{baseUrl}}/providers/openai/test",
              "host": ["{{baseUrl}}"],
              "path": ["providers", "openai", "test"]
            },
            "description": "Test OpenAI connectivity and API key validity. Returns 404 if OpenAI is not registered."
          },
          "event": [
            {
              "listen": "test",
              "script": {

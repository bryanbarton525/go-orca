{
  "info": {
    "_postman_id": "a1b2c3d4-e5f6-7890-abcd-ef1234567890",
    "name": "go-orca API",
    "description": "Complete API collection for go-orca — a self-hosted AI workflow orchestration server.\n\n## Setup\n\n1. Set the `baseUrl` collection variable to your server address (default: `http://localhost:8080`).\n2. Run **Health → GET /readyz** to confirm the server is up.\n3. Run **Tenants → List Tenants** — this auto-captures `tenantId` and `scopeId` from the default tenant.\n4. Run **Workflows → Create Workflow (Software)** to kick off your first workflow. `workflowId` is captured automatically.\n\n## Variables\n\n| Variable | Set by |\n|---|---|\n| `baseUrl` | You — set once at collection level |\n| `tenantId` | Auto-set by List Tenants or Create Tenant |\n| `scopeId` | Auto-set by List Tenants or Create Scope |\n| `workflowId` | Auto-set by Create Workflow requests |\n| `createdTenantId` | Auto-set by Create Tenant |\n| `createdScopeId` | Auto-set by Create Scope |",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080",
      "type": "string",
      "description": "Base URL of the go-orca API server"
    },
    {
      "key": "tenantId",
      "value": "",
      "type": "string",
      "description": "Active tenant UUID — auto-set by List Tenants or Create Tenant"
    },
    {
      "key": "scopeId",
      "value": "",
      "type": "string",
      "description": "Active scope UUID — auto-set by List Tenants or Create Scope"
    },
    {
      "key": "workflowId",
      "value": "",
      "type": "string",
      "description": "Active workflow UUID — auto-set by Create Workflow requests"
    },
    {
      "key": "createdTenantId",
      "value": "",
      "type": "string",
      "description": "UUID of the most recently created tenant"
    },
    {
      "key": "createdScopeId",
      "value": "",
      "type": "string",
      "description": "UUID of the most recently created scope"
    }
  ],
  "item": [
    {
      "name": "Health",
      "description": "Liveness and readiness probes. Use these to verify the server is up and connected to its dependencies.",
      "item": [
        {
          "name": "Liveness — GET /healthz",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/healthz",
              "host": ["{{baseUrl}}"],
              "path": ["healthz"]
            },
            "description": "Returns 200 immediately without touching the database. Use as a Kubernetes livenessProbe."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('status is 200', () => pm.response.to.have.status(200));",
                  "pm.test('body has status ok', () => {",
                  "    const body = pm.response.json();",
                  "    pm.expect(body.status).to.eql('ok');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Readiness — GET /readyz",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/readyz",
              "host": ["{{baseUrl}}"],
              "path": ["readyz"]
            },
            "description": "Returns 200 if the database and all registered providers are reachable. Returns 503 if any dependency is unavailable. Use as a Kubernetes readinessProbe."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('status is 200 or 503', () => {",
                  "    pm.expect(pm.response.code).to.be.oneOf([200, 503]);",
                  "});",
                  "if (pm.response.code === 200) {",
                  "    pm.test('body has status ready', () => {",
                  "        pm.expect(pm.response.json().status).to.eql('ready');",
                  "    });",
                  "} else {",
                  "    pm.test('body has error detail', () => {",
                  "        pm.expect(pm.response.json()).to.have.property('error');",
                  "    });",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Workflows",
      "description": "Create and manage AI workflow runs. A workflow drives a natural-language request through the Director → PM → Architect → Implementer → QA → Finalizer pipeline.",
      "item": [
        {
          "name": "List Workflows",
          "request": {
            "method": "GET",
            "header": [
              { "key": "X-Tenant-ID", "value": "{{tenantId}}", "description": "Omit to use server default" },
              { "key": "X-Scope-ID", "value": "{{scopeId}}", "description": "Omit to use server default" }
            ],
            "url": {
              "raw": "{{baseUrl}}/workflows?limit=20&offset=0",
              "host": ["{{baseUrl}}"],
              "path": ["workflows"],
              "query": [
                { "key": "limit", "value": "20", "description": "Max results (max 200)" },
                { "key": "offset", "value": "0", "description": "Pagination offset" }
              ]
            },
            "description": "Returns workflows for the current tenant/scope, ordered newest first."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('status is 200', () => pm.response.to.have.status(200));",
                  "pm.test('response is an array', () => {",
                  "    pm.expect(pm.response.json()).to.be.an('array');",
                  "});",
                  "// Auto-capture the most recent workflow ID if present",
                  "const workflows = pm.response.json();",
                  "if (workflows.length > 0) {",
                  "    pm.collectionVariables.set('workflowId', workflows[0].id);",
                  "    console.log('workflowId set to', workflows[0].id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Create Workflow — Software",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "X-Tenant-ID", "value": "{{tenantId}}", "description": "Omit to use server default" },
              { "key": "X-Scope-ID", "value": "{{scopeId}}", "description": "Omit to use server default" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"request\": \"Build a REST API for a todo list in Go with CRUD endpoints and SQLite storage\",\n  \"title\": \"Todo API\",\n  \"mode\": \"software\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/workflows",
              "host": ["{{baseUrl}}"],
              "path": ["workflows"]
            },
            "description": "Create a software workflow. The Director will classify the request and select a provider/model if not specified. Returns 202 with status `pending`."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('status is 201 or 202', () => {",
                  "    pm.expect(pm.response.code).to.be.oneOf([201, 202]);",
                  "});",
                  "const body = pm.response.json();",
                  "pm.test('has workflow id', () => pm.expect(body).to.have.property('id'));",
                  "pm.test('status is pending', () => pm.expect(body.status).to.eql('pending'));",
                  "pm.collectionVariables.set('workflowId', body.id);",
                  "console.log('workflowId set to', body.id);"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },

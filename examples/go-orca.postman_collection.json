        {
          "name": "Create Workflow — Explicit Model Override",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "X-Tenant-ID", "value": "{{tenantId}}", "description": "Required unless the server injects a default tenant" },
              { "key": "X-Scope-ID", "value": "{{scopeId}}", "description": "Required unless the server injects a default scope" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"request\": \"Build a Go CLI that prints the sum of even numbers in a slice and includes unit tests\",\n  \"title\": \"Sum Even CLI\",\n  \"mode\": \"software\",\n  \"provider\": \"ollama\",\n  \"model\": \"qwen3:1.7b\"\n}",

              "raw": "{\n  \"request\": \"Write a short technical note explaining Go interfaces versus generics with one concise code example\",\n  \"title\": \"Interfaces vs Generics\",\n  \"mode\": \"docs\",\n  \"delivery\": {\n    \"action\": \"markdown-export\"\n  }\n}",
